flowchart TB
  subgraph IF["Interface layer (context)"]
    UI["Civil Business UI"]
    IFAPI["Interface API\n(idempotency at ingress)"]
    IFDB["Interface DB\n(InputReport, attachments, comments)\n+ Outbox"]
    UI --> IFAPI --> IFDB
  end

  subgraph BUS["Event Bus / Router (unspecified transport)"]
    EB["CloudEvents stream\n(structured JSON)"]
  end

  subgraph CO["Coordination layer"]
    COSVC["Workflow / Events / Logic"]
    CODB["Coordination DB\n(OutputReport, ServiceRequest, WorkOrder)\n+ Outbox"]
    COSVC <--> CODB
  end

  subgraph IN["Integration layer"]
    INSVC["Integration workers\n(sync read-only enrichment optional)\n(async side effects via events)"]
    INDB["Integration store (optional)\n(request/result tracking)"]
    INSVC <--> INDB
  end

  subgraph GOV["Governance layer"]
    GOVSVC["Rules / Policy / Audit"]
    AUDS["Audit store (append-only)\n(policy findings store optional)"]
    GOVSVC <--> AUDS
  end

  %% Async event paths
  IFDB -.->|"outbox publish"| EB
  EB -.->|"deliver"| COSVC
  COSVC -.->|"outbox publish"| EB
  EB -.->|"deliver"| INSVC
  EB -.->|"deliver"| GOVSVC
  GOVSVC -.->|"policy finding publish (optional)"| EB
  EB -.->|"deliver"| COSVC